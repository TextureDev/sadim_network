<body>
    
  <div class="grid-bg"></div>

  <header>
    <a href="{{ url_for('loading_bp.landing_page') }}" class="brand">SADEEM</a>
    <a href="{{ url_for('Library_Agatha.agatha_christie') }}" class="back-btn">
      <i class="fa-solid fa-arrow-right" style="font-size:12px;"></i>
      العودة للمكتبة
    </a>
  </header>

  <div class="container">
    <div class="book-layout">

      <div class="cover-wrap">
        <img 
          src="{{ url_for('Library_Agatha.static', filename='uploads/' + book['cover_path']) }}?v={{ book['id'] }}" 
          alt="{{ book['title'] }}"
        >
        <div class="download-badge">
          <i class="fa-solid fa-cloud-arrow-down" style="font-size:14px;"></i>
          <span>{{ book['download_count'] or 0 }} تحميل</span>
        </div>
      </div>

      <div class="book-meta">
        <p class="book-author">أجاثا كريستي</p>
        <h1 class="book-title">{{ book['title'] }}</h1>
        <div class="divider"></div>
        <p class="book-desc">{{ book['desc_text'] }}</p>

        <div class="actions">
          <a 
            href="{{ url_for('Library_Agatha.download_file', book_id=book['id']) }}"
            class="btn-download"
            onclick="updateCount({{ book['id'] }})"
          >
            <i class="fa-solid fa-download" style="font-size:14px;"></i>
            تحميل PDF ملكي
          </a>

          <a href="{{ url_for('Library_Agatha.agatha_christie') }}" class="btn-back">
            <i class="fa-solid fa-books" style="font-size:14px;"></i>
            روايات أخرى
          </a>
        </div>

        <div class="comment-area">
            <h3>آراء القراء</h3>

            {% if session.get('user_id') %}
            <form action="{{ url_for('Library_Agatha.add_comment', book_id=book.id) }}" method="POST" class="comment-form">
                <textarea name="content" rows="3" placeholder="اكتب انطباعك الملكي عن هذه الرواية..." required></textarea>
                <button type="submit" class="btn-download" style="padding: 10px 20px;">نشر التعليق</button>
            </form>
            {% else %}
            <p class="book-desc" style="font-size: 13px; margin-bottom: 1rem;">يرجى <a href="{{ url_for('loading_bp.login') }}" style="color: var(--gold);">تسجيل الدخول</a> لترك تعليق.</p>
            {% endif %}

            <div style="margin-top: 2rem;">
                {% for comment in comments %}
                <div class="comment-item" style="display: flex; gap: 15px; align-items: flex-start; margin-bottom: 1.5rem;">
                    
                    <div class="user-avatar">
                        <img src="{{ url_for('static', filename='uploads/profiles/' + (comment.profile_image if comment.profile_image else 'default.png')) }}" 
                             style="width: 42px; height: 42px; border-radius: 50%; border: 1px solid var(--border); object-fit: cover;">
                    </div>

                    <div style="flex: 1;">
                        <div class="comment-user" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <span>
                                <i class="fa-solid fa-user-crown" style="font-size: 11px; color: var(--gold); margin-left: 5px;"></i>
                                {{ comment.username if comment.username else "مستخدم رقم #" ~ comment.user_id }}
                            </span>

                            {% if session.get('user_id') == comment.user_id %}
                            <div class="comment-actions">
                                <a href="{{ url_for('Library_Agatha.delete_comment', comment_id=comment.id, book_id=book.id) }}" 
                                   onclick="return confirm('هل أنت متأكد من الحذف؟')"
                                   style="color: var(--text-muted); font-size: 12px; transition: color 0.2s;"
                                   onmouseover="this.style.color='#ff4d4d'" onmouseout="this.style.color='var(--text-muted)'">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                            {% endif %}
                        </div>
                        
                        <p class="comment-text" style="color: var(--text-secondary); font-size: 14px; line-height: 1.6;">{{ comment.content }}</p>
                        <small class="comment-date" style="color: var(--text-muted); font-size: 11px; display: block; margin-top: 5px;">
                            {{ comment.created_at.strftime('%Y-%m-%d %H:%M') if comment.created_at else '' }}
                        </small>
                    </div>
                </div>
                {% else %}
                <p class="book-desc" style="font-size: 13px; text-align: center;">لا توجد تعليقات بعد. كن أول من يضع بصمته.</p>
                {% endfor %}
            </div>
        </div>
      </div>

    </div>
  </div>

  <footer>
    <a href="https://sadim.cloud">sadim.cloud</a>
  </footer>

  <script>
    function updateCount(bookId) {
      fetch(`/library/increment_download/${bookId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          const badge = document.querySelector('.download-badge span');
          if (badge) badge.textContent = data.new_count + ' تحميل';
        }
      })
      .catch(err => console.error(err));
    }
  </script>
</body>